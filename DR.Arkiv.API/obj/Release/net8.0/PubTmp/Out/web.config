      <aspNetCore processPath="dotnet" arguments=".\DR.Arkiv.API.dll" stdoutLogEnabled="false" stdoutLogFile="\\?\%home%\LogFiles\stdout" hostingModel="inprocess" />
    </system.webServer>
  </location>
</configuration>
